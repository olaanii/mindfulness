# Copy to firebase.env in this folder (gitignored). Used by all platforms including Web.
# Firebase Console → Project settings → Your apps, or `flutterfire configure` output.
#
# Client keys still ship in the app; protect data with Rules + optional App Check.

# Shared
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com

# Web
FIREBASE_WEB_API_KEY=
FIREBASE_WEB_APP_ID=

# Android
FIREBASE_ANDROID_API_KEY=
FIREBASE_ANDROID_APP_ID=

# iOS (and default fallback for macOS if macOS-specific vars are omitted)
FIREBASE_IOS_API_KEY=
FIREBASE_IOS_APP_ID=
FIREBASE_IOS_BUNDLE_ID=com.example.app

# Optional: macOS app (otherwise iOS values are used)
# FIREBASE_MACOS_API_KEY=
# FIREBASE_MACOS_APP_ID=
# FIREBASE_MACOS_BUNDLE_ID=

# Windows (often registered as a web app in Firebase)
FIREBASE_WINDOWS_API_KEY=
FIREBASE_WINDOWS_APP_ID=
